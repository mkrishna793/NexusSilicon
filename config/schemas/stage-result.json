{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StageResult",
  "type": "object",
  "properties": {
    "stage": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "finding.json"
      }
    }
  },
  "required": ["stage", "status", "inputs", "outputs", "metrics", "findings"]
}
